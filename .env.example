# 主财务数据库。
DATABASE_URL=postgresql://fina:fina123@postgres:5432/fina

# 独立记忆数据库。
# 如果你暂时不想单独部署，可以改成和 DATABASE_URL 相同。
MEMORY_DATABASE_URL=postgresql://fina_memory:fina_memory123@memory_postgres:5432/fina_memory

# AI 服务配置。
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.deepseek.com/v1

# 默认模型名。
# 这里必须填“模型名”，不要填 API Key。
AI_MODEL=deepseek-chat

# 可选模型白名单，使用英文逗号分隔。
# 留空表示允许调用方临时指定任意 OpenAI 兼容模型。
# 如果想锁定范围，可以像下面这样配置：
# AI_ALLOWED_MODELS=deepseek-chat,deepseek-reasoner,gpt-4o-mini,gpt-4.1-mini,qwen-max,glm-4.5-air
AI_ALLOWED_MODELS=

# 管理接口令牌。
ADMIN_TOKEN=change_me

# JWT 密钥。
JWT_SECRET=change_me_too

# Stripe 集成配置。
# STRIPE_API_KEY 主要用于后续服务端补查对象。
# STRIPE_WEBHOOK_SECRET 用于校验 webhook 签名。
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# 导出文件目录。
EXPORTS_DIR=/app/exports
