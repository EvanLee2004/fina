# PostgreSQL 连接地址。
# 当前默认使用 Docker Compose 内部网络地址，通过服务名 postgres 访问数据库。
# 如果你是在宿主机本地直接运行 FastAPI，而不是放在 Docker 里跑，
# 这里需要改成 localhost。
DATABASE_URL=postgresql://fina:fina123@postgres:5432/fina

# JWT 签名密钥。
# 当前认证主要走 X-Admin-Token，这个字段先作为备用安全配置保留。
JWT_SECRET=change-this-to-a-strong-secret

# 通用 AI 服务访问密钥。
# 这里提交到仓库时保持为空，使用时再手动填写真实值。
AI_API_KEY=

# OpenAI 兼容接口基础地址。
# 当前默认接 DeepSeek 的兼容入口，后续如需切换其他兼容服务商只改这里即可。
AI_BASE_URL=https://api.deepseek.com/v1

# 默认模型名称。
# 当前默认使用 DeepSeek 的 deepseek-chat。
AI_MODEL=deepseek-chat

# 后台管理访问令牌。
# 所有 /api/admin/* 请求都需要在 Header 中带上 X-Admin-Token。
ADMIN_TOKEN=fina-admin-secret-2024
